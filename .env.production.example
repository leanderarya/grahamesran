APP_NAME="Graha Motor"
APP_ENV=production
APP_KEY=  # Will be generated on server
APP_DEBUG=false
APP_URL=https://grahamotor.cahayaarkana.site

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=30

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u123456789_grahamotor
DB_USERNAME=u123456789_grahamotor
DB_PASSWORD=  # Set your DB password from Hostinger hPanel

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=grahamotor.cahayaarkana.site
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

SANCTUM_STATEFUL_DOMAINS=grahamotor.cahayaarkana.site

MAIL_MAILER=log
